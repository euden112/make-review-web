GROQ_API_KEY=your_groq_api_key_here
# 키 여러 개 사용 시 (쉼표 구분, 429 감지 시 자동 전환)
# GROQ_API_KEYS=key1,key2,key3
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# Map 단계 백엔드: groq(클라우드 기본, Ollama 불필요) 또는 local(로컬 Ollama).
# 미설정 시 docker-compose가 groq로 강제. 첫 요약을 로컬 GPU로 돌릴 땐
# /api/v1/games/{id}/summarize?map_backend=local 로 요청별 override.
MAP_BACKEND=groq
# Groq map 모델 (미설정 시 GROQ_MODEL 사용)
# GROQ_MAP_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
API_SECRET_KEY=your_secret_key_here

# 스케줄러 증분 크롤 설정
# 크롤 잡이 ingestion을 자기호출할 백엔드 주소 (compose 기본: http://backend:8000)
# INTERNAL_API_BASE=http://backend:8000
# Steam 최신순 수집 깊이(언어당). 하루치 신규 리뷰를 덮을 정도면 충분.
CRAWL_RECENT_PER_LANG=100

# 로컬 Map(map_backend=local) 경로 전용 — 평소(groq)엔 불필요.
# 첫 요약을 로컬 GPU로 돌릴 때만 설정. 로컬 Ollama를 cloudflared로 노출한 URL.
# 예: cloudflared tunnel --url http://localhost:11434  → 아래에 발급 URL(끝 슬래시 없이).
# OLLAMA_BASE_URL=https://xxxx.trycloudflare.com
# LOCAL_MAP_MODEL=gemma4:e4b

# Frontend API base.
# Leave empty in Docker/nginx deployment so /api is proxied by frontend/nginx.conf.
# For local Vite dev without proxy, set this to http://localhost:8000.
VITE_API_BASE=
