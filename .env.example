GROQ_API_KEY=your_groq_api_key_here
# 키 여러 개 사용 시 (쉼표 구분, 429 감지 시 자동 전환)
# GROQ_API_KEYS=key1,key2,key3
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
API_SECRET_KEY=your_secret_key_here

# Frontend API base.
# Leave empty in Docker/nginx deployment so /api is proxied by frontend/nginx.conf.
# For local Vite dev without proxy, set this to http://localhost:8000.
VITE_API_BASE=
